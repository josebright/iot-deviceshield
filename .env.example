# ============================================================================
# IoT-DeviceShield — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ---- Node / runtime -------------------------------------------------------
NODE_ENV=development

# ---- API (apps/api) -------------------------------------------------------
API_PORT=3000

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=deviceshield
DB_PASSWORD=change-me-in-real-env
DB_NAME=iot_deviceshield

# JWT auth (Phase 3) — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-48-byte-random-string
JWT_EXPIRES_IN=1h

# CORS: origin of the web app (Phase 3)
FRONTEND_URL=http://localhost:3001

# ---- External integrations ------------------------------------------------
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# NIST NVD is public and requires no key, but adding one raises rate limits.
# Request at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# ---- Observability (Phase 6, optional) ------------------------------------
# SENTRY_DSN=

# ---- Web (apps/web) — Next.js public envs must be prefixed NEXT_PUBLIC_ ----
NEXT_PUBLIC_API_URL=http://localhost:3000/v1
# NEXT_PUBLIC_SENTRY_DSN=
