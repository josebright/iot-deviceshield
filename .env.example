# Node / runtime
NODE_ENV=development

# API (apps/api)
API_PORT=3000

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=deviceshield
DB_PASSWORD=change-me-in-real-env
DB_NAME=iot_deviceshield

# JWT auth — generate with: openssl rand -base64 48
JWT_SECRET=replace-with-48-byte-random-string
JWT_EXPIRES_IN=1h

# CORS: origin of the web app
FRONTEND_URL=http://localhost:3001

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# NIST NVD — optional; raises rate limits when set.
# Request at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Sentry — optional; when unset, Sentry.init() is skipped and every
# capture call is a no-op.
SENTRY_DSN=

# Web (apps/web) — Next.js public envs must be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:3000/v1
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload (build-time only; requires an auth token
# from https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/).
# When SENTRY_AUTH_TOKEN is unset, the build skips source-map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=iot-deviceshield
SENTRY_PROJECT=iot-deviceshield-frontend
