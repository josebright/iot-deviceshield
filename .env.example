# Node / runtime
NODE_ENV=development

# API (apps/api)
API_PORT=3000

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=deviceshield
DB_PASSWORD=change-me-in-real-env
DB_NAME=iot_deviceshield

# Admin surface bearer token. Guards /v1/admin/* and /v1/catalog/* mutating routes.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=replace-with-64-hex-chars

# CORS origin of the web app
FRONTEND_URL=http://localhost:3001

# AI enrichment (local, via Ollama). Set AI_ENABLED=false to skip AI text
# generation entirely; CVE data still comes through.
AI_ENABLED=true
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_PORT=11434

# NIST NVD. Optional. Without a key, NIST caps at 5 requests / 30 seconds.
# With a free key, 50 / 30 seconds. Register at:
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Per-client rate limits, keyed on request fingerprint.
CLIENT_RATE_LIMIT_PER_MIN=60
CLIENT_VULN_RATE_LIMIT_PER_MIN=10

# Catalog sync schedule (cron format) and cache windows.
CATALOG_REFRESH_CRON=0 3 * * *
CVE_CACHE_MINUTES=30
CPE_RESOLVE_TTL_DAYS=30

# When true, the API pre-warms the vulnerabilities cache for every catalog
# device in the background 15 s after boot. Users hitting the site never wait
# for the cold LLM path. Set false during development to skip the warmer.
WARM_CACHE_ON_BOOT=true

# Sentry error reporting. Leave blank to skip; the SDK becomes a no-op.
SENTRY_DSN=

# Web app (apps/web). Next.js public env vars must be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_API_URL=http://localhost:3000/v1
# Server-side fetches (Server Components) use this so they can reach the API
# on the internal Docker network. Falls back to NEXT_PUBLIC_API_URL when unset.
INTERNAL_API_URL=http://api:3000/v1
NEXT_PUBLIC_SENTRY_DSN=

# Sentry source-map upload during the web build. Only needed for release
# tagging; skipped automatically when SENTRY_AUTH_TOKEN is blank.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=iot-deviceshield
SENTRY_PROJECT=iot-deviceshield-frontend
