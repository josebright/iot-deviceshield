# ============================================================================
# pnpm settings — repository-wide.
# Keep these strict; when they conflict with a specific dep, fix the dep.
# ============================================================================

# Fail fast if any transitive peer dep is missing/mismatched.
# Nest, Passport, and Sentry are all peer-dep heavy — this catches broken graphs early.
strict-peer-dependencies=true

# Auto-install peers so we don't have to manually mirror them in every workspace.
auto-install-peers=true

# Refuse to fall back to npm's registry silently; if a workspace needs a private registry
# it must configure it explicitly.
prefer-frozen-lockfile=true

# Reject 'workspace:' protocol resolutions when publishing (belt-and-braces).
save-workspace-protocol=rolling

# Isolate workspaces — do NOT hoist to a shared root by default. Each package sees
# only what it declared. Catches "works on my machine because it was hoisted" bugs.
hoist=true
public-hoist-pattern[]=@types/*
public-hoist-pattern[]=typescript
public-hoist-pattern[]=prettier
public-hoist-pattern[]=eslint

# Deprecation-warning noise reduction: pnpm surfaces every deprecated transitive on
# every install. Keep default behavior (warn), but pin the max lines shown.
loglevel=warn

# Store the pnpm store under the OS default (~/.local/share/pnpm/store) —
# ensures Turborepo remote caching works across projects. Don't override per-repo.

# Do not save exact versions by default in package.json — semver ranges (^) are correct
# for libraries. Lockfile pins the resolved version for reproducibility.
save-prefix=^

# When resolving GitHub Actions and CI, prefer the offline mirror if the tarball is cached.
# Keeps CI fast even if the registry is flaky.
prefer-offline=true
